# Gemini (recommended) — Chat Completions via OpenAI-compatible endpoint
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Optional Gemini model id (default: gemini-2.0-flash). Alias: GEMINI_MODEL
# GOOGLE_AI_MODEL=gemini-2.0-flash

# Optional override base URL (default: Google OpenAI-compat v1beta)
# GOOGLE_AI_BASE_URL=

# OpenAI fallback when GOOGLE_AI_API_KEY is unset
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Azure / proxy when using OPENAI_* only
# OPENAI_BASE_URL=

# Postgres (Phase 4+); optional comma-separated origins for FastAPI CORS.
# Railway: add Postgres plugin (or Supabase pooled URL). Pre-deploy applies supabase/migrations/*.sql.
# DATABASE_URL=

# Optional: comma-separated origins to restrict browsers (omit for allow-all — default).
# Needed only if you want a lockdown beyond the default permissive API CORS.
# Example: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# CORS_ORIGINS=
